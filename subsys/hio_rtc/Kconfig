config HIO_RTC
	bool "HIO_RTC"
	depends on SHELL
	select EVENTS
	select NRFX_RTC0 if SOC_SERIES_NRF52X || SOC_SERIES_NRF91X
	# nrfx v4.1+ (NCS 3.4) replaced per-instance NRFX_RTCn symbols
	select NRFX_RTC if SOC_SERIES_NRF52 || SOC_SERIES_NRF91
	select NRFX_GRTC if SOC_SERIES_NRF54LX || SOC_SERIES_NRF54L
	select POLL

if HIO_RTC

module = HIO_RTC
module-str = HIO Real-time Clock Subsystem
source "subsys/logging/Kconfig.template.log_config"

config HIO_RTC_INIT_PRIORITY
	int "Initialization priority"
	default 3

endif # HIO_RTC
