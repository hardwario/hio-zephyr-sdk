config HIO_ATCI
	bool "HIO_ATCI"
	select CRC

if HIO_ATCI

rsource "backends/Kconfig.backends"

config HIO_ATCI_STACK_SIZE
	int "ATCI thread stack size"
	default 2048 if MULTITHREADING
	default 0 if !MULTITHREADING
	help
	  Stack size for thread created for each instance.

config HIO_ATCI_CMD_SHELL
	bool "ATCI command shell"
	default y if SHELL
	select SHELL_BACKEND_DUMMY

config HIO_ATCI_CMD_SHELL_AUTH_FLAGS
	int "ATCI command shell authentication flags"
	default 1 if HIO_ATCI_LOGIN
	default 0

config HIO_ATCI_CMD_REBOOT
	bool "ATCI command reboot"
	default y
	select HIO_SYS
	help
	  Enable ATCI command for rebooting the device.

config HIO_ATCI_CMD_REBOOT_AUTH_FLAGS
	int "ATCI command reboot authentication flags"
	default 1 if HIO_ATCI_LOGIN
	default 0
	help
	  Authentication flags for ATCI command reboot.
	  It is used to restrict access to the reboot command.

config HIO_ATCI_LOGIN
	bool "ATCI login authentication"
	select HIO_CONFIG
	help
	  Enable ATCI login authentication. Registers a hio_config module with
	  a "passphrase-hash" item (SHA-256 hash hex string), the
	  AT$LOGIN/AT$LOGOUT commands, and an ATCI auth-check callback that
	  gates commands with non-zero auth flags behind an authenticated
	  session.

config HIO_ATCI_LOGIN_DEFAULT_PASSPHRASE_HASH
	string "Default passphrase hash (SHA-256 hex)"
	depends on HIO_ATCI_LOGIN
	default ""
	help
	  Compile-time default for the "passphrase-hash" config item: a SHA-256
	  hash of the passphrase as a 64-character lowercase hex string. When a
	  device has no stored passphrase, this value is used.

	  Intended for development builds (a known passphrase baked into the
	  firmware). Leave empty for production and provision the hash at
	  runtime via the shell or ATCI. A passphrase set at runtime overrides
	  this default.

	  Example (passphrase "hardwario"):
	    printf '%s' hardwario | sha256sum

config HIO_ATCI_LOGIN_BOOT_DELAY
	int "Login boot delay (seconds)"
	depends on HIO_ATCI_LOGIN
	default 5
	help
	  Authentication attempts are rejected for this many seconds after
	  boot. Prevents brute-force attacks combined with device resets.

config HIO_ATCI_LOGIN_MAX_ATTEMPTS
	int "Failed login attempts before cooldown"
	depends on HIO_ATCI_LOGIN
	default 5
	help
	  Number of consecutive failed authentication attempts after which
	  the login cooldown is activated.

config HIO_ATCI_LOGIN_COOLDOWN
	int "Login cooldown duration (seconds)"
	depends on HIO_ATCI_LOGIN
	default 300
	help
	  Authentication attempts are rejected for this many seconds after
	  too many consecutive failed attempts.

config HIO_ATCI_LOGIN_INIT_PRIORITY
	int "ATCI login init priority"
	depends on HIO_ATCI_LOGIN
	default 99
	help
	  Initialization priority for registering the ATCI login configuration
	  module. Must run after the HIO_CONFIG subsystem is initialized.

choice HIO_ATCI_LOGIN_HASH
	prompt "Login password hash backend"
	depends on HIO_ATCI_LOGIN
	default HIO_ATCI_LOGIN_HASH_MBEDTLS

config HIO_ATCI_LOGIN_HASH_MBEDTLS
	bool "mbedTLS"
	select NRF_SECURITY
	select MBEDTLS_LEGACY_CRYPTO_C
	select MBEDTLS_SHA256_C
	select MBEDTLS_ENABLE_HEAP

config HIO_ATCI_LOGIN_HASH_TINYCRYPT
	bool "TinyCrypt"
	select TINYCRYPT
	select TINYCRYPT_SHA256

config HIO_ATCI_LOGIN_HASH_PSA
	bool "PSA Crypto"
	select NRF_SECURITY
	# With TF-M the PSA crypto API is provided by the secure image
	select MBEDTLS_PSA_CRYPTO_C if !BUILD_WITH_TFM
	select PSA_WANT_ALG_SHA_256

endchoice

config HIO_ATCI_CMD_BUFF_SIZE
	int "ATCI command buffer size"
	default 256
	help
	  Maximum command size in bytes. One byte is reserved for the string
	  terminator character.

config HIO_ATCI_PRINTF_BUFF_SIZE
	int "ATCI print buffer size"
	default 30
	help
	  Maximum text buffer size for fprintf function.
	  It is working like stdio buffering in Linux systems
	  to limit number of peripheral access calls.

config HIO_ATCI_URC_BUFF_SIZE
	int "ATCI deferred URC buffer size"
	default 128
	help
	  Buffer used to defer URC (broadcast) messages emitted while a command
	  is being processed on the same instance. Deferred messages are
	  flushed right after the command response is finished. Messages that
	  do not fit into the buffer are dropped.

choice
	prompt "ATCI CRC mode"
	default HIO_ATCI_CRC_MODE_OPTIONAL

config HIO_ATCI_CRC_MODE_DISABLED
	bool "Disabled"
	help
	  CRC is not used at all.

config HIO_ATCI_CRC_MODE_STRICT
	bool "Strict"
	help
	  CRC must be present and valid. Otherwise, the command is rejected.

config HIO_ATCI_CRC_MODE_OPTIONAL
	bool "Optional"
	help
	  CRC is verified if present. If not present, the command is accepted.
endchoice

config HIO_ATCI_CRC_MODE
	int "ATCI CRC mode"
	default 0 if HIO_ATCI_CRC_MODE_DISABLED
	default 1 if HIO_ATCI_CRC_MODE_STRICT
	default 2 if HIO_ATCI_CRC_MODE_OPTIONAL

config HIO_ATCI_LOG_BACKEND
	bool "ATCI log backend"
	select LOG_OUTPUT
	default y if LOG

config HIO_ATCI_LOG_FORMAT_TIMESTAMP
	bool "Format timestamp"
	default y
	help
	  Enable timestamp formatting.

config HIO_ATCI_MODEM_TRACE
	bool "Modem trace output"
	default n
	select NRF_MODEM_LIB_TRACE
	select BASE64

choice NRF_MODEM_LIB_TRACE_BACKEND
    prompt "Modem trace backend"
    default NRF_MODEM_LIB_TRACE_BACKEND_RAM if HIO_ATCI_MODEM_TRACE
endchoice

config HIO_ATCI_CMD_FW
	bool "HIO ATCI DFU"
	default y if DFU_TARGET_MCUBOOT && MCUBOOT_IMG_MANAGER
	help
	  Enable HIO ATCI DFU support.

config HIO_ATCI_CMD_FW_AUTH_FLAGS
	int "HIO ATCI DFU authentication flags"
	default 1 if HIO_ATCI_LOGIN
	default 0
	help
	  Authentication flags for HIO ATCI DFU command.
	  It is used to restrict access to the DFU command.

module = HIO_ATCI
module-str = HIO ATCI Subsystem
source "subsys/logging/Kconfig.template.log_config"

endif # HIO_ATCI
